---
import { Image } from "astro:assets"
import ChevronRight from "@/assets/icons/ChevronRight.astro"
import dAppBoosterLogo from "@assets/dAppBoosterLogo.svg"
---

<div class="headerWrapper">
  <header>
    <nav aria-label="Main navigation">
      <a href="/">
        <Image
          class="logo"
          src={dAppBoosterLogo}
          height={76}
          width={190}
          loading="eager"
          alt="dAppBooster - A blockchain boilerplate to kickstart your next Web3 project"
        />
      </a>
      <a
        href="https://demo.dappbooster.dev/"
        target="_blank"
        rel="noopener noreferrer"
        class="button"
        ><span>Launch your <span>next</span> dApp</span> <ChevronRight /></a
      >
    </nav>
  </header>
</div>

<style>
  .headerWrapper {
    position: relative;
  }
  header {
    padding: calc(var(--space) * 2) 0;
    position: absolute;
    z-index: 10;
    width: 100%;
  }
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: var(--maxWidth);
    margin: 0 auto;
    padding: 0 calc(var(--space) * 4);
    width: 100%;
    @media only screen and (max-width: 1024px) {
      padding: 0 calc(var(--space) * 2);
    }
  }
  .logo {
    height: 76px;
    width: auto;
    @media only screen and (max-width: 768px) {
      height: 60px;
    }
  }
  a.button {
    color: var(--greyLightest);
    font-weight: 700;
    display: flex;
    align-items: center;
    padding: var(--space) calc(var(--space) * 2) var(--space)
      calc(var(--space) * 3);
    gap: calc(var(--space) * 2);
    border-radius: 30px;
    background: var(--secondaryLight);
    text-decoration: none;
    box-shadow:
      0px 9.6px 13px 0px rgba(0, 0, 0, 0.08),
      0px 2.1px 4.625px 0px rgba(0, 0, 0, 0.05);

    &:hover,
    &:focus-visible {
      background: var(--secondary);
    }
    @media only screen and (max-width: 768px) {
      font-size: 1.3rem;
      gap: var(--space);
      padding: var(--space) var(--space) var(--space) calc(var(--space) * 2);
      > span > span {
        display: none;
      }
    }
  }
</style>
